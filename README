│  ├─ layout.css
│  ├─ components.css
│  ├─ sections.css
│  └─ utilities.css
├─ js/
│  └─ script.js
├─ img/
└─ README.md
```

---

## Run Locally

```bash
git clone https://github.com/Armin-000/portfolio
cd portfolio
open index.html
```

